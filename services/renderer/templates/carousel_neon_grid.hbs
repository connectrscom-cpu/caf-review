<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root { --safe: 80px; --void: #0a0a0f; --grid: rgba(0, 255, 255, 0.12); --neon-cyan: #00ffff; --neon-magenta: #ff00aa; --neon-glow: rgba(0, 255, 255, 0.4); --bone: #e0e8ec; --muted: #6a7a88; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: var(--void); }
    .slide {
      width: 1080px; height: 1350px;
      overflow: hidden;
      flex-shrink: 0;
      border: 1px solid rgba(0, 255, 255, 0.2);
    }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: var(--safe);
      text-align: center;
      background: var(--void);
      box-sizing: border-box;
    }
    .grid-bg { position: absolute; inset: 0; z-index: 0; background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px); background-size: 60px 60px; opacity: 0.8; transform: perspective(400px) rotateX(55deg); transform-origin: 50% 100%; }
    .grid-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 0%, var(--void) 70%); pointer-events: none; }
    .scanlines { position: absolute; inset: 0; z-index: 1; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.15) 2px, rgba(0,0,0,0.15) 4px); pointer-events: none; }
    .corner { position: absolute; width: 80px; height: 80px; border-color: var(--neon-cyan); border-style: solid; border-width: 0; z-index: 1; }
    .corner.tl { top: 40px; left: 40px; border-top-width: 3px; border-left-width: 3px; box-shadow: 0 0 20px var(--neon-glow); }
    .corner.tr { top: 40px; right: 40px; border-top-width: 3px; border-right-width: 3px; box-shadow: 0 0 20px var(--neon-glow); }
    .corner.bl { bottom: 40px; left: 40px; border-bottom-width: 3px; border-left-width: 3px; box-shadow: 0 0 20px var(--neon-glow); }
    .corner.br { bottom: 40px; right: 40px; border-bottom-width: 3px; border-right-width: 3px; box-shadow: 0 0 20px var(--neon-glow); }
    .title-neon { font-family: 'Orbitron', sans-serif; font-size: clamp(58px, 6.2vw, 76px); font-weight: 800; color: var(--neon-cyan); text-shadow: 0 0 30px var(--neon-glow), 0 0 60px rgba(0,255,255,0.2); position: relative; z-index: 2; line-height: 1.2; max-width: 820px; letter-spacing: 0.02em; }
    .subtitle-mono { font-family: 'JetBrains Mono', monospace; font-size: clamp(32px, 3.2vw, 40px); color: var(--muted); margin-top: 24px; z-index: 2; position: relative; letter-spacing: 0.2em; }
    .subtitle-mono::before { content: '> '; color: var(--neon-magenta); }
    .body-title { font-family: 'Orbitron', sans-serif; font-size: clamp(48px, 5vw, 58px); font-weight: 600; color: var(--neon-cyan); text-shadow: 0 0 20px var(--neon-glow); margin-bottom: 28px; z-index: 2; position: relative; }
    .body-text { font-family: 'Outfit', sans-serif; font-size: clamp(34px, 3.4vw, 42px); line-height: 1.45; color: var(--bone); max-width: 700px; position: relative; z-index: 2; text-align: center; }
    .cta-neon { font-family: 'Orbitron', sans-serif; font-size: clamp(52px, 5.5vw, 66px); font-weight: 800; color: var(--neon-magenta); text-shadow: 0 0 30px rgba(255,0,170,0.5); z-index: 2; position: relative; }
    .cta-handle { font-family: 'JetBrains Mono', monospace; font-size: clamp(36px, 3.6vw, 42px); color: var(--neon-cyan); margin-top: 18px; z-index: 2; position: relative; }
    .slide-inner .cover-title { font-family: 'Orbitron', sans-serif; font-size: clamp(72px, 8vw, 96px); font-weight: 800; color: var(--neon-cyan); text-shadow: 0 0 40px var(--neon-glow), 0 0 80px rgba(0,255,255,0.3); z-index: 2; position: relative; letter-spacing: 0.08em; line-height: 1.1; }
    .slide-inner .cover-subtitle { font-family: 'JetBrains Mono', monospace; font-size: clamp(36px, 3.6vw, 44px); color: var(--neon-magenta); margin-top: 28px; z-index: 2; position: relative; letter-spacing: 0.3em; }
  </style>
</head>
<body>
  <div class="slide cover">
    <div class="slide-inner">
      <div class="grid-bg"></div>
      <div class="scanlines"></div>
      <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
      <span class="cover-title">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
      {{#if cover_subtitle}}<span class="cover-subtitle">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="cover-subtitle">{{cover_slide.body}}</span>{{/if}}{{/if}}
    </div>
  </div>
  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="grid-bg"></div>
      <div class="scanlines"></div>
      <span class="corner tl"></span><span class="corner br"></span>
      <span class="body-title">{{headline}}</span>
      <p class="body-text">{{body}}</p>
    </div>
  </div>
  {{/each}}
  <div class="slide">
    <div class="slide-inner">
      <div class="grid-bg"></div>
      <div class="scanlines"></div>
      <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>
      <span class="cta-neon">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
      {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
    </div>
  </div>
</body>
</html>
