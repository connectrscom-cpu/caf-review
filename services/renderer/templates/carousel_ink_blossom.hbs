<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700&family=Outfit:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --safe: 80px;
      --ink: #1a1814;
      --paper: #f6f2ec;
      --blossom: #c17f7a;
      --blossom-soft: rgba(193, 127, 122, 0.35);
      --stem: #5c6b5a;
      --muted: #6b6259;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: var(--ink); color: var(--ink); }
    .slide {
      width: 1080px;
      height: 1350px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .slide-inner {
      width: 100%;
      height: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: var(--safe);
      text-align: center;
      background: var(--paper);
      box-sizing: border-box;
    }
    .blossom-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      opacity: 0.08;
      background-image: url("data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Cellipse cx='60' cy='60' rx='20' ry='45' fill='%23c17f7a' transform='rotate(0 60 60)'/%3E%3Cellipse cx='60' cy='60' rx='20' ry='45' fill='%23c17f7a' transform='rotate(72 60 60)'/%3E%3Cellipse cx='60' cy='60' rx='20' ry='45' fill='%23c17f7a' transform='rotate(144 60 60)'/%3E%3Cellipse cx='60' cy='60' rx='20' ry='45' fill='%23c17f7a' transform='rotate(216 60 60)'/%3E%3Cellipse cx='60' cy='60' rx='20' ry='45' fill='%23c17f7a' transform='rotate(288 60 60)'/%3E%3Ccircle cx='60' cy='60' r='12' fill='%23c17f7a'/%3E%3C/svg%3E");
      background-size: 140px 140px;
    }
    .blossom-accent {
      position: absolute;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, var(--blossom-soft), transparent 70%);
      z-index: 0;
    }
    .blossom-accent.a1 { top: 8%; right: 5%; }
    .blossom-accent.a2 { bottom: 15%; left: 8%; }
    .cover-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(72px, 8vw, 96px);
      font-weight: 600;
      color: var(--ink);
      line-height: 1.1;
      max-width: 820px;
      position: relative;
      z-index: 1;
    }
    .cover-subtitle {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(34px, 3.6vw, 42px);
      color: var(--muted);
      margin-top: 24px;
      position: relative;
      z-index: 1;
    }
    .body-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(52px, 5.5vw, 64px);
      font-weight: 600;
      color: var(--blossom);
      margin-bottom: 28px;
      position: relative;
      z-index: 1;
    }
    .body-text {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(36px, 3.8vw, 44px);
      line-height: 1.45;
      color: var(--ink);
      max-width: 680px;
      position: relative;
      z-index: 1;
      text-align: center;
    }
    .cta-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(58px, 6.2vw, 72px);
      font-weight: 600;
      color: var(--ink);
      position: relative;
      z-index: 1;
      margin-bottom: 16px;
    }
    .cta-handle {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(36px, 3.6vw, 44px);
      color: var(--stem);
      position: relative;
      z-index: 1;
    }
  </style>
</head>
<body>
  <!-- Slide 1: Cover -->
  <div class="slide">
    <div class="slide-inner">
      <div class="blossom-bg"></div>
      <span class="blossom-accent a1"></span>
      <span class="blossom-accent a2"></span>
      <span class="cover-title">{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{#if cover}}{{cover}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
      {{#if cover_slide.body}}<span class="cover-subtitle">{{cover_slide.body}}</span>{{else}}{{#if cover_subtitle}}<span class="cover-subtitle">{{cover_subtitle}}</span>{{/if}}{{/if}}
    </div>
  </div>
  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <div class="blossom-bg"></div>
      <span class="blossom-accent a2"></span>
      <span class="body-title">{{headline}}</span>
      <p class="body-text">{{body}}</p>
    </div>
  </div>
  {{/each}}
  <!-- CTA -->
  <div class="slide">
    <div class="slide-inner">
      <div class="blossom-bg"></div>
      <span class="blossom-accent a1"></span>
      <span class="blossom-accent a2"></span>
      <span class="cta-text">{{#if cta_slide.body}}{{cta_slide.body}}{{else}}{{#if cta_text}}{{cta_text}}{{/if}}{{/if}}</span>
      {{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{else}}{{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{/if}}{{/if}}
    </div>
  </div>
</body>
</html>
