# Supabase (CAF Storage) — content and decisions live here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Protect decision endpoint
REVIEW_WRITE_TOKEN=

# Optional: notify n8n after saving decision to Supabase
DECISION_WEBHOOK_URL=

# Renderer (stable URL; no hardcoded tunnel). Used by n8n and CAF Backend UI.
RENDERER_BASE_URL=http://localhost:3333

# On the renderer (e.g. Fly), set CAF_TEMPLATE_API_URL to this app URL so it can load templates saved from the Playground.
# Example: CAF_TEMPLATE_API_URL=https://your-caf-app.vercel.app

# Review Queue (Validation Google Sheet). Console shows tasks; backend writes decision fields.
# Auth: use EITHER service account OR OAuth2 (no service account key needed).
 GOOGLE_REVIEW_QUEUE_SPREADSHEET_ID=  # Spreadsheet ID from the sheet URL
 GOOGLE_REVIEW_QUEUE_SHEET_NAME=Review Queue
# --- Service account (if you can create keys) ---
 GOOGLE_SERVICE_ACCOUNT_JSON=        # Full service account JSON string (serverless)
 GOOGLE_APPLICATION_CREDENTIALS=     # Or path to key file (local). Share sheet with SA email (Editor).
# --- OAuth2 (when you cannot create service account keys) — see docs/review-queue-oauth-setup.md ---
# GOOGLE_CLIENT_ID=                  # OAuth 2.0 Client ID (Desktop or Web app)
# GOOGLE_CLIENT_SECRET=              # OAuth 2.0 Client secret
# GOOGLE_REFRESH_TOKEN=              # Refresh token from one-time consent (Sheet must be accessible by this Google account)
# Optional
NEXT_PUBLIC_APP_URL=http://localhost:3000
CACHE_TTL_SECONDS=15
NEXT_PUBLIC_REVIEW_WRITE_TOKEN=
