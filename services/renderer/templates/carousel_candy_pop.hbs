<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080, height=1350">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600&family=Nunito:wght@600;700&family=Outfit:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root { --safe: 80px; --cream: #fff8f5; --pink: #ff6b9d; --pink-soft: rgba(255,107,157,0.25); --cyan: #00d4aa; --cyan-soft: rgba(0,212,170,0.2); --yellow: #ffd93d; --yellow-soft: rgba(255,217,61,0.25); --purple: #b388ff; --purple-soft: rgba(179,136,255,0.2); --ink: #2d2430; --muted: #6b5b75; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: linear-gradient(165deg, #fff8f5 0%, #ffe8f0 40%, #f5f0ff 100%); }
    .slide {
      width: 1080px; height: 1350px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .slide-inner {
      width: 100%; height: 100%;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: var(--safe);
      text-align: center;
      background: linear-gradient(165deg, #fff8f5 0%, #ffe8f0 40%, #f5f0ff 100%);
      box-sizing: border-box;
    }
    .bubble { position: absolute; border-radius: 50%; z-index: 0; box-shadow: inset -8px -8px 20px rgba(255,255,255,0.6), inset 4px 4px 12px rgba(0,0,0,0.06); }
    .bubble.pink { background: radial-gradient(circle at 30% 30%, #ff8ab0, var(--pink)); }
    .bubble.cyan { background: radial-gradient(circle at 35% 35%, #40e0c8, var(--cyan)); }
    .bubble.yellow { background: radial-gradient(circle at 30% 30%, #ffe066, var(--yellow)); }
    .bubble.purple { background: radial-gradient(circle at 35% 35%, #c9a8ff, var(--purple)); }
    .bubble.b1 { width: 200px; height: 200px; top: 8%; right: 10%; }
    .bubble.b2 { width: 140px; height: 140px; top: 35%; left: 5%; }
    .bubble.b3 { width: 180px; height: 180px; bottom: 15%; right: 15%; }
    .bubble.b4 { width: 100px; height: 100px; bottom: 30%; left: 18%; }
    .bubble.b5 { width: 160px; height: 160px; top: 55%; right: 8%; }
    .bubble.b6 { width: 120px; height: 120px; top: 20%; left: 25%; }
    .blob { position: absolute; border-radius: 50% 45% 55% 50% / 50% 55% 45% 50%; z-index: 0; }
    .blob.p { width: 400px; height: 400px; background: var(--pink-soft); top: -100px; right: -80px; }
    .blob.c { width: 350px; height: 350px; background: var(--cyan-soft); bottom: -80px; left: -100px; }
    .blob.y { width: 280px; height: 280px; background: var(--yellow-soft); top: 40%; left: -50px; }
    .title-candy { font-family: 'Fredoka', sans-serif; font-size: clamp(72px, 7.5vw, 92px); font-weight: 600; color: var(--ink); line-height: 1.1; position: relative; z-index: 2; max-width: 820px; text-shadow: 3px 3px 0 var(--pink-soft), -1px -1px 0 rgba(255,255,255,0.8); }
    .subtitle-candy { font-family: 'Nunito', sans-serif; font-size: clamp(42px, 4.2vw, 52px); font-weight: 700; color: var(--pink); margin-top: 24px; position: relative; z-index: 2; }
    .body-title { font-family: 'Fredoka', sans-serif; font-size: clamp(58px, 6vw, 72px); font-weight: 600; color: var(--purple); margin-bottom: 28px; position: relative; z-index: 2; }
    .body-text { font-family: 'Outfit', sans-serif; font-size: clamp(36px, 3.6vw, 44px); line-height: 1.45; color: var(--ink); max-width: 700px; position: relative; z-index: 2; text-align: center; }
    .cta-candy { font-family: 'Fredoka', sans-serif; font-size: clamp(68px, 7vw, 88px); font-weight: 600; color: var(--cyan); position: relative; z-index: 2; text-shadow: 2px 2px 0 var(--cyan-soft); }
    .cta-handle { font-family: 'Nunito', sans-serif; font-size: clamp(44px, 4.4vw, 52px); font-weight: 700; color: var(--pink); margin-top: 20px; position: relative; z-index: 2; }
    .slide-inner .cover-title { font-family: 'Fredoka', sans-serif; font-size: clamp(88px, 9vw, 110px); font-weight: 600; color: var(--ink); line-height: 1.05; position: relative; z-index: 2; text-shadow: 4px 4px 0 var(--pink-soft), 6px 6px 0 var(--purple-soft), 2px 2px 0 rgba(255,255,255,0.9); }
    .slide-inner .cover-subtitle { font-family: 'Nunito', sans-serif; font-size: clamp(44px, 4.4vw, 54px); font-weight: 700; color: var(--pink); margin-top: 28px; position: relative; z-index: 2; }
  </style>
</head>
<body>
  <div class="slide cover">
    <div class="slide-inner">
      <span class="blob p"></span>
      <span class="blob c"></span>
      <span class="blob y"></span>
      <span class="bubble pink b1"></span>
      <span class="bubble cyan b2"></span>
      <span class="bubble yellow b6"></span>
      <span class="bubble purple b3"></span>
      <span class="cover-title">{{#if cover}}{{cover}}{{else}}{{#if cover_slide}}{{cover_slide.headline}}{{else}}{{intro_title}}{{/if}}{{/if}}</span>
      {{#if cover_subtitle}}<span class="cover-subtitle">{{cover_subtitle}}</span>{{else}}{{#if cover_slide.body}}<span class="cover-subtitle">{{cover_slide.body}}</span>{{/if}}{{/if}}
    </div>
  </div>
  {{#each body_slides}}
  <div class="slide">
    <div class="slide-inner">
      <span class="blob c"></span>
      <span class="bubble purple b3"></span>
      <span class="bubble pink b4"></span>
      <span class="bubble cyan b5"></span>
      <span class="body-title">{{headline}}</span>
      <p class="body-text">{{body}}</p>
    </div>
  </div>
  {{/each}}
  <div class="slide">
    <div class="slide-inner">
      <span class="blob p"></span>
      <span class="blob c"></span>
      <span class="bubble yellow b1"></span>
      <span class="bubble pink b3"></span>
      <span class="bubble purple b6"></span>
      <span class="cta-candy">{{#if cta_text}}{{cta_text}}{{else}}{{#if cta_slide}}{{cta_slide.body}}{{/if}}{{/if}}</span>
      {{#if cta_handle}}<span class="cta-handle">{{cta_handle}}</span>{{else}}{{#if cta_slide.handle}}<span class="cta-handle">{{cta_slide.handle}}</span>{{/if}}{{/if}}
    </div>
  </div>
</body>
</html>
