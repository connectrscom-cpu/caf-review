# Supabase (CAF Storage) — content and decisions live here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Protect decision endpoint
REVIEW_WRITE_TOKEN=

# Optional: notify n8n after saving decision to Supabase
DECISION_WEBHOOK_URL=

# Renderer (stable URL; no hardcoded tunnel). Used by n8n and CAF Backend UI.
RENDERER_BASE_URL=http://localhost:3333

# On the renderer (e.g. Fly), set CAF_TEMPLATE_API_URL to this app URL so it can load templates saved from the Playground.
# Example: CAF_TEMPLATE_API_URL=https://your-caf-app.vercel.app

# Optional
NEXT_PUBLIC_APP_URL=http://localhost:3000
CACHE_TTL_SECONDS=15
NEXT_PUBLIC_REVIEW_WRITE_TOKEN=
